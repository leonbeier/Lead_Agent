NODE_ENV=development
PORT=3000
DEFAULT_MARKET=Europe
DEFAULT_TARGET_LEADS=50

# Required app auth for protected server and embedded HubSpot UI.
LEAD_AGENT_SHARED_KEY=
LEAD_AGENT_PUBLIC_BASE_URL=http://localhost:3000

# Company discovery providers.
APOLLO_API_KEY=
APOLLO_BASE_URL=https://api.apollo.io/api/v1
EXA_API_KEY=
EXA_MAX_BUDGET_USD=20
EXA_REQUEST_TIMEOUT_MS=90000
DIFFBOT_TOKEN=

# HubSpot. The runtime variable used by this app is HUBSPOT_PRIVATE_APP_TOKEN.
# HUBSPOT_ACCESS_TOKEN is kept here because GitHub/Copilot issue templates may ask for it.
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_BASE_URL=https://api.hubapi.com

# OpenAI web-search path.
OPENAI_API_KEY=
OPENAI_WEB_SEARCH_MODEL=gpt-5.4-mini
OPENAI_PRE_RESEARCH_MODEL=
OPENAI_DEEP_RESEARCH_MODEL=
OPENAI_WEB_SEARCH_ENABLED=true

# Azure OpenAI.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_CLASSIFIER_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_AI_CLASSIFICATION_CONCURRENCY=10
AZURE_OPENAI_INPUT_COST_PER_1K_TOKENS=0
AZURE_OPENAI_OUTPUT_COST_PER_1K_TOKENS=0
AZURE_OPENAI_MAX_COST_USD=5

# Optional Azure AI / Foundry path.
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT=
FOUNDRY_BING_CONNECTION_NAME=
FOUNDRY_USE_AGENT_FILTERS=false
FOUNDRY_USE_AGENT_QUALIFICATION=false
FOUNDRY_USE_AGENT_RESEARCH=false
AZURE_RESEARCH_ENABLED=false
AZURE_RESEARCH_ENDPOINT=

# Runtime tuning.
CONTACT_DISCOVERY_CONCURRENCY=8
HUBSPOT_SYNC_CONCURRENCY=6

# Budget aliases kept for compatibility with existing code paths.
AI_COST_INPUT_EUR_PER_MILLION=
AI_COST_INPUT_EUR_PER_MILLION_TOKENS=
AI_COST_OUTPUT_EUR_PER_MILLION=
AI_COST_OUTPUT_EUR_PER_MILLION_TOKENS=
AI_DAILY_BUDGET_EUR=

# Local or CI deploy helpers. These are not required by the runtime server.
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=